{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:extension",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "run",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "compile",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "run",
        "compile"
      ],
      "problemMatcher": "$tsc",
      "group": "build"
    },
    {
      "label": "test",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "test"
      ],
      "problemMatcher": []
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "run",
        "clean"
      ],
      "problemMatcher": []
    }
  ]
}
