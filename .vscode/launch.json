{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/extensions",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build"
    },
    {
      "name": "Debug Extension + Copilot",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data-copilot",
        "--extensions-dir=${env:EXTENSIONS_DIR}",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "env": {
        "EXTENSIONS_DIR": "${env:USERPROFILE}/.vscode/extensions"
      },
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build"
    },
    {
      "name": "Debug Extension (Current Profile)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build"
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/dist/test/suite/index",
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/extensions"
      ],
      "outFiles": ["${workspaceFolder}/dist/test/**/*.js"],
      "preLaunchTask": "build"
    }
  ]
}
