{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/extensions",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Run Extension + Copilot Chat",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data-copilot",
        "--extensions-dir=C:/Users/admin/.vscode/extensions",
        "--disable-extension=openai.chatgpt",
        "--disable-extension=RooVeterinaryInc.roo-cline",
        "--disable-extension=kilocode.kilo-code",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Run Extension + Copilot Chat (Current Profile)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensions-dir=C:/Users/admin/.vscode/extensions",
        "--disable-extension=openai.chatgpt",
        "--disable-extension=RooVeterinaryInc.roo-cline",
        "--disable-extension=kilocode.kilo-code",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    },
    {
      "name": "Extension Tests",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--extensionTestsPath=${workspaceFolder}/dist/test/suite/index",
        "--disable-extensions",
        "--user-data-dir=${workspaceFolder}/.vscode-test/user-data",
        "--extensions-dir=${workspaceFolder}/.vscode-test/extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/test/**/*.js"
      ],
      "preLaunchTask": "${defaultBuildTask}"
    }
  ]
}
