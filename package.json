{
  "name": "prompt-by-prompt",
  "displayName": "Prompt by Prompt",
  "description": "VS Code extension: treat prompts as first-class code (Prompt as Code)",
  "version": "1.5.0",
  "publisher": "aknirex",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aknirex/prompt-by-prompt.git"
  },
  "homepage": "https://github.com/Aknirex/prompt-by-prompt#readme",
  "license": "GPL-3.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": "^24.0.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "prompt",
    "ai",
    "llm",
    "ollama",
    "openai",
    "claude",
    "prompt-engineering"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:pbp.promptsView",
    "onView:pbp.rulesView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbp.refreshPrompts",
        "title": "%command.pbp.refreshPrompts%",
        "icon": "$(refresh)"
      },
      {
        "command": "pbp.createPrompt",
        "title": "%command.pbp.createPrompt%",
        "icon": "$(add)"
      },
      {
        "command": "pbp.editPrompt",
        "title": "%command.pbp.editPrompt%"
      },
      {
        "command": "pbp.deletePrompt",
        "title": "%command.pbp.deletePrompt%"
      },
      {
        "command": "pbp.runPrompt",
        "title": "%command.pbp.runPrompt%",
        "icon": "$(play)"
      },
      {
        "command": "pbp.openSettings",
        "title": "%command.pbp.openSettings%",
        "icon": "$(gear)"
      },
      {
        "command": "pbp.refreshRules",
        "title": "%command.pbp.refreshRules%",
        "icon": "$(refresh)"
      },
      {
        "command": "pbp.addRule",
        "title": "%command.pbp.addRule%",
        "icon": "$(add)"
      },
      {
        "command": "pbp.deleteRule",
        "title": "%command.pbp.deleteRule%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pbp-explorer",
          "title": "%viewContainer.pbp-explorer%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pbp-explorer": [
        {
          "id": "pbp.promptsView",
          "name": "%view.pbp.promptsView%",
          "icon": "media/icon.svg"
        },
        {
          "id": "pbp.rulesView",
          "name": "%view.pbp.rulesView%",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pbp.refreshPrompts",
          "when": "view == pbp.promptsView",
          "group": "navigation@1"
        },
        {
          "command": "pbp.createPrompt",
          "when": "view == pbp.promptsView",
          "group": "navigation@2"
        },
        {
          "command": "pbp.openSettings",
          "when": "view == pbp.promptsView",
          "group": "navigation@3"
        },
        {
          "command": "pbp.refreshRules",
          "when": "view == pbp.rulesView",
          "group": "navigation@1"
        },
        {
          "command": "pbp.addRule",
          "when": "view == pbp.rulesView",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "pbp.runPrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "inline"
        },
        {
          "command": "pbp.editPrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "1_modification"
        },
        {
          "command": "pbp.deletePrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "1_modification"
        },
        {
          "command": "pbp.deleteRule",
          "when": "view == pbp.rulesView && viewItem == rule",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "pbp.runPrompt",
          "group": "pbp"
        }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "pbp.defaultModel": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "anthropic",
            "azure",
            "deepseek",
            "google",
            "groq",
            "mistral",
            "ollama",
            "openai",
            "openrouter",
            "xai"
          ],
          "description": "%config.pbp.defaultModel.description%"
        },
        "pbp.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "%config.pbp.ollamaEndpoint.description%"
        },
        "pbp.ollamaModel": {
          "type": "string",
          "default": "llama3.2",
          "description": "%config.pbp.ollamaModel.description%"
        },
        "pbp.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.openaiApiKey.description%"
        },
        "pbp.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "%config.pbp.openaiModel.description%"
        },
        "pbp.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.claudeApiKey.description%"
        },
        "pbp.claudeModel": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "%config.pbp.claudeModel.description%"
        },
        "pbp.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.groqApiKey.description%"
        },
        "pbp.groqModel": {
          "type": "string",
          "default": "llama-3.3-70b-versatile",
          "description": "%config.pbp.groqModel.description%"
        },
        "pbp.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.geminiApiKey.description%"
        },
        "pbp.geminiModel": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "%config.pbp.geminiModel.description%"
        },
        "pbp.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.openrouterApiKey.description%"
        },
        "pbp.openrouterModel": {
          "type": "string",
          "default": "anthropic/claude-3.5-sonnet",
          "description": "%config.pbp.openrouterModel.description%"
        },
        "pbp.deepseekApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.deepseekApiKey.description%"
        },
        "pbp.deepseekModel": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "%config.pbp.deepseekModel.description%"
        },
        "pbp.mistralApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.mistralApiKey.description%"
        },
        "pbp.mistralModel": {
          "type": "string",
          "default": "mistral-large-latest",
          "description": "%config.pbp.mistralModel.description%"
        },
        "pbp.xaiApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.xaiApiKey.description%"
        },
        "pbp.xaiModel": {
          "type": "string",
          "default": "grok-beta",
          "description": "%config.pbp.xaiModel.description%"
        },
        "pbp.azureApiKey": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.azureApiKey.description%"
        },
        "pbp.azureEndpoint": {
          "type": "string",
          "default": "",
          "description": "%config.pbp.azureEndpoint.description%"
        },
        "pbp.azureModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "%config.pbp.azureModel.description%"
        },
        "pbp.promptsDir": {
          "type": "string",
          "default": ".prompts",
          "description": "%config.pbp.promptsDir.description%"
        },
        "pbp.defaultAgent": {
          "type": "string",
          "enum": [
            "ask",
            "cline",
            "roo-code",
            "copilot",
            "continue",
            "clipboard"
          ],
          "default": "ask",
          "description": "%config.pbp.defaultAgent.description%"
        },
        "pbp.rememberLastAgent": {
          "type": "boolean",
          "default": true,
          "description": "%config.pbp.rememberLastAgent.description%"
        },
        "pbp.defaultTarget": {
          "type": "string",
          "enum": [
            "workspace",
            "global"
          ],
          "default": "global",
          "description": "%config.pbp.defaultTarget.description%"
        },
        "pbp.outputDirectory": {
          "type": "string",
          "default": ".prompts/output",
          "description": "%config.pbp.outputDirectory.description%"
        },
        "pbp.defaultRuleFile": {
          "type": "string",
          "default": "ask",
          "description": "%config.pbp.defaultRuleFile.description%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run esbuild-base -- --minify",
    "clean": "rimraf dist",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc --noEmit",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "build": "npm run esbuild-base -- --minify",
    "lint": "eslint src",
    "test": "echo \"No tests to run\"",
    "test:watch": "vitest",
    "package": "vsce package",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "ovsx": "^0.10.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1",
    "uuid": "^13.0.0"
  }
}
