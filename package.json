{
  "name": "prompt-by-prompt",
  "displayName": "Prompt by Prompt",
  "description": "A focused prompt manager for VS Code: save, search, preview, and reuse prompts as files.",
  "version": "3.1.0",
  "publisher": "aknirex",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aknirex/prompt-by-prompt.git"
  },
  "homepage": "https://github.com/Aknirex/prompt-by-prompt#readme",
  "license": "GPL-3.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": "^20.20.2"
  },
  "packageManager": "pnpm@10.33.0",
  "volta": {
    "node": "20.20.2",
    "pnpm": "10.33.0"
  },
  "categories": [
    "Snippets",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "prompt",
    "prompt-manager",
    "prompt-engineering",
    "ai",
    "llm"
  ],
  "activationEvents": [
    "onView:pbp.promptsView",
    "onCommand:pbp.refreshPrompts",
    "onCommand:pbp.createPrompt",
    "onCommand:pbp.searchPrompts",
    "onCommand:pbp.copyPrompt",
    "onCommand:pbp.previewPrompt",
    "onCommand:pbp.editPrompt",
    "onCommand:pbp.duplicatePrompt",
    "onCommand:pbp.deletePrompt",
    "onCommand:pbp.toggleFavoritePrompt",
    "onCommand:pbp.openPromptFile",
    "onCommand:pbp.openPromptLibrary"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbp.refreshPrompts",
        "title": "Refresh Prompts",
        "icon": "$(refresh)"
      },
      {
        "command": "pbp.createPrompt",
        "title": "New Prompt",
        "icon": "$(add)"
      },
      {
        "command": "pbp.searchPrompts",
        "title": "Search Prompts",
        "icon": "$(search)"
      },
      {
        "command": "pbp.copyPrompt",
        "title": "Copy Rendered Prompt",
        "icon": "$(clippy)"
      },
      {
        "command": "pbp.previewPrompt",
        "title": "Preview Rendered Prompt",
        "icon": "$(preview)"
      },
      {
        "command": "pbp.editPrompt",
        "title": "Edit Prompt",
        "icon": "$(edit)"
      },
      {
        "command": "pbp.duplicatePrompt",
        "title": "Duplicate Prompt",
        "icon": "$(copy)"
      },
      {
        "command": "pbp.deletePrompt",
        "title": "Delete Prompt",
        "icon": "$(trash)"
      },
      {
        "command": "pbp.toggleFavoritePrompt",
        "title": "Toggle Favorite",
        "icon": "$(star-full)"
      },
      {
        "command": "pbp.openPromptFile",
        "title": "Open Prompt File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "pbp.openPromptLibrary",
        "title": "Open Prompt Library",
        "icon": "$(folder-opened)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pbp-explorer",
          "title": "Prompt by Prompt",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pbp-explorer": [
        {
          "id": "pbp.promptsView",
          "name": "Prompts",
          "icon": "media/icon.svg"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pbp.refreshPrompts",
          "when": "view == pbp.promptsView",
          "group": "navigation@1"
        },
        {
          "command": "pbp.createPrompt",
          "when": "view == pbp.promptsView",
          "group": "navigation@2"
        },
        {
          "command": "pbp.searchPrompts",
          "when": "view == pbp.promptsView",
          "group": "navigation@3"
        },
        {
          "command": "pbp.openPromptLibrary",
          "when": "view == pbp.promptsView",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "pbp.copyPrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user || viewItem == prompt.builtin)",
          "group": "inline@1"
        },
        {
          "command": "pbp.previewPrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user || viewItem == prompt.builtin)",
          "group": "1_run@1"
        },
        {
          "command": "pbp.toggleFavoritePrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user || viewItem == prompt.builtin)",
          "group": "1_run@2"
        },
        {
          "command": "pbp.editPrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user)",
          "group": "2_manage@1"
        },
        {
          "command": "pbp.duplicatePrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user || viewItem == prompt.builtin)",
          "group": "2_manage@2"
        },
        {
          "command": "pbp.openPromptFile",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user || viewItem == prompt.builtin)",
          "group": "2_manage@3"
        },
        {
          "command": "pbp.deletePrompt",
          "when": "view == pbp.promptsView && (viewItem == prompt.workspace || viewItem == prompt.user)",
          "group": "2_manage@4"
        }
      ],
      "editor/context": [
        {
          "command": "pbp.searchPrompts",
          "when": "editorTextFocus",
          "group": "pbp"
        }
      ]
    },
    "configuration": {
      "title": "Prompt by Prompt",
      "properties": {
        "pbp.libraryPath": {
          "type": "string",
          "default": ".prompts",
          "description": "Workspace folder that stores prompt YAML files."
        },
        "pbp.defaultPromptTarget": {
          "type": "string",
          "enum": [
            "workspace",
            "user"
          ],
          "default": "workspace",
          "description": "Where new and duplicated prompts are saved by default."
        },
        "pbp.includeFileContext": {
          "type": "boolean",
          "default": true,
          "description": "Include the active file content in the {{file_content}} render variable."
        },
        "pbp.showBuiltInPrompts": {
          "type": "boolean",
          "default": true,
          "description": "Show bundled starter prompts in the prompt library."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run clean && pnpm run build",
    "clean": "rimraf dist",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc --noEmit",
    "watch": "pnpm run esbuild-base --sourcemap --watch",
    "build": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "lint": "eslint src",
    "check:i18n": "node scripts/check-i18n.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package --no-dependencies",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/vscode": "1.85.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.2.1",
    "ovsx": "^0.10.12",
    "release-it": "^20.0.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "8.0.10"
    }
  }
}
