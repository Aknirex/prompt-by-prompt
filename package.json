{
  "name": "prompt-by-prompt",
  "displayName": "Prompt by Prompt",
  "description": "VS Code extension: treat prompts as first-class code (Prompt as Code)",
  "version": "1.0.1",
  "publisher": "aknirex",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aknirex/prompt-by-prompt.git"
  },
  "homepage": "https://github.com/Aknirex/prompt-by-prompt#readme",
  "license": "GPL-3.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0",
    "node": "^24.0.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Machine Learning",
    "Other"
  ],
  "keywords": [
    "prompt",
    "ai",
    "llm",
    "ollama",
    "openai",
    "claude",
    "prompt-engineering"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pbp.refreshPrompts",
        "title": "Refresh Prompts",
        "icon": "$(refresh)"
      },
      {
        "command": "pbp.createPrompt",
        "title": "Create New Prompt",
        "icon": "$(add)"
      },
      {
        "command": "pbp.editPrompt",
        "title": "Edit Prompt"
      },
      {
        "command": "pbp.deletePrompt",
        "title": "Delete Prompt"
      },
      {
        "command": "pbp.runPrompt",
        "title": "Run Prompt",
        "icon": "$(play)"
      },
      {
        "command": "pbp.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "pbp-explorer",
          "title": "Prompt by Prompt",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "pbp-explorer": [
        {
          "id": "pbp.promptsView",
          "name": "Prompts"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "pbp.refreshPrompts",
          "when": "view == pbp.promptsView",
          "group": "navigation@1"
        },
        {
          "command": "pbp.createPrompt",
          "when": "view == pbp.promptsView",
          "group": "navigation@2"
        },
        {
          "command": "pbp.openSettings",
          "when": "view == pbp.promptsView",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "pbp.runPrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "inline"
        },
        {
          "command": "pbp.editPrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "1_modification"
        },
        {
          "command": "pbp.deletePrompt",
          "when": "view == pbp.promptsView && viewItem == prompt",
          "group": "1_modification"
        }
      ],
      "editor/context": [
        {
          "command": "pbp.runPrompt",
          "group": "pbp"
        }
      ]
    },
    "configuration": {
      "title": "Prompt by Prompt",
      "properties": {
        "pbp.defaultModel": {
          "type": "string",
          "default": "ollama",
          "enum": [
            "anthropic",
            "azure",
            "deepseek",
            "google",
            "groq",
            "mistral",
            "ollama",
            "openai",
            "openrouter",
            "xai"
          ],
          "description": "Default AI provider for prompt generation"
        },
        "pbp.ollamaEndpoint": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama API endpoint"
        },
        "pbp.ollamaModel": {
          "type": "string",
          "default": "llama3.2",
          "description": "Default Ollama model"
        },
        "pbp.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key"
        },
        "pbp.openaiModel": {
          "type": "string",
          "default": "gpt-4o-mini",
          "description": "Default OpenAI model"
        },
        "pbp.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key"
        },
        "pbp.claudeModel": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "Default Anthropic model"
        },
        "pbp.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API Key"
        },
        "pbp.groqModel": {
          "type": "string",
          "default": "llama-3.3-70b-versatile",
          "description": "Default Groq model"
        },
        "pbp.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Google AI API Key"
        },
        "pbp.geminiModel": {
          "type": "string",
          "default": "gemini-2.0-flash",
          "description": "Default Google AI model"
        },
        "pbp.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API Key"
        },
        "pbp.openrouterModel": {
          "type": "string",
          "default": "anthropic/claude-3.5-sonnet",
          "description": "Default OpenRouter model (format: provider/model)"
        },
        "pbp.deepseekApiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API Key"
        },
        "pbp.deepseekModel": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Default DeepSeek model"
        },
        "pbp.mistralApiKey": {
          "type": "string",
          "default": "",
          "description": "Mistral AI API Key"
        },
        "pbp.mistralModel": {
          "type": "string",
          "default": "mistral-large-latest",
          "description": "Default Mistral AI model"
        },
        "pbp.xaiApiKey": {
          "type": "string",
          "default": "",
          "description": "xAI (Grok) API Key"
        },
        "pbp.xaiModel": {
          "type": "string",
          "default": "grok-beta",
          "description": "Default xAI model"
        },
        "pbp.azureApiKey": {
          "type": "string",
          "default": "",
          "description": "Azure OpenAI API Key"
        },
        "pbp.azureEndpoint": {
          "type": "string",
          "default": "",
          "description": "Azure OpenAI endpoint URL"
        },
        "pbp.azureModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "Default Azure OpenAI deployment name"
        },
        "pbp.promptsDir": {
          "type": "string",
          "default": ".prompts",
          "description": "Directory name for workspace prompts"
        },
        "pbp.defaultAgent": {
          "type": "string",
          "enum": [
            "ask",
            "cline",
            "roo-code",
            "copilot",
            "continue",
            "clipboard"
          ],
          "default": "ask",
          "description": "Default agent to send prompts to. 'ask' will prompt every time."
        },
        "pbp.rememberLastAgent": {
          "type": "boolean",
          "default": true,
          "description": "Remember the last used agent"
        },
        "pbp.defaultTarget": {
          "type": "string",
          "enum": [
            "workspace",
            "global"
          ],
          "default": "global",
          "description": "Default save location for new prompts"
        },
        "pbp.outputDirectory": {
          "type": "string",
          "default": ".prompts/output",
          "description": "Directory for generated markdown files (relative to workspace or absolute path)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run clean && npm run esbuild-base -- --minify",
    "clean": "rimraf dist",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "compile": "tsc --noEmit",
    "watch": "npm run esbuild-base -- --sourcemap --watch",
    "build": "npm run esbuild-base -- --minify",
    "lint": "eslint src",
    "test": "echo \"No tests to run\"",
    "test:watch": "vitest",
    "package": "vsce package",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "ovsx": "^0.10.0",
    "release-it": "^19.2.4",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "handlebars": "^4.7.8",
    "js-yaml": "^4.1.1",
    "uuid": "^13.0.0"
  }
}
